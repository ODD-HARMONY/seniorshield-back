# === Gemini API ===
GEMINI_API_KEY=

# === 모델 이름 (사용자 지정) ===
MODEL_CLASSIFY=gemini-2.0-flash
MODEL_INFO=gemini-2.5-flash-preview-05-20
MODEL_IMAGE=gemini-2.0-flash-lite

# === Google Fact Check Tools API ===
GOOGLE_FACTCHECK_API_KEY=

# === MariaDB ===
MARIADB_ROOT_PASSWORD=changeme
MARIADB_DATABASE=seniorshield
MARIADB_USER=ss_user
MARIADB_PASSWORD=ss_pass

# === 서비스 타임아웃 (ms) ===
EXTRACTOR_TIMEOUT_MS=30000
ANALYZER_TIMEOUT_MS=20000
FACTCHECK_TIMEOUT_MS=10000

# === 캐시 TTL (일) ===
CACHE_TTL_DAYS=14

# === 추출 옵션 ===
MAX_DURATION_SEC=120
FRAME_COUNT=3
