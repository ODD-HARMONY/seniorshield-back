<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
  <display-name>SeniorShield Gateway</display-name>

  <!-- §5.2: Rate limit filter — /api/suspicion POST에만 적용 -->
  <filter>
    <filter-name>RateLimitFilter</filter-name>
    <filter-class>com.seniorshield.filter.RateLimitFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>RateLimitFilter</filter-name>
    <url-pattern>/api/suspicion/*</url-pattern>
  </filter-mapping>
  <filter-mapping>
    <filter-name>RateLimitFilter</filter-name>
    <url-pattern>/api/suspicion</url-pattern>
  </filter-mapping>
</web-app>
